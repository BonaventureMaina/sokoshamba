{
  "name": "sokoshamba-backend",
  "version": "1.0.0",
  "description": "SokoShamba Backend API - Farm to Consumer Marketplace",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "db:reset": "prisma migrate reset && npm run db:seed",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.ts\""
  },
  "keywords": [
    "marketplace",
    "agriculture",
    "kenya",
    "e-commerce"
  ],
  "author": "SokoShamba",
  "license": "UNLICENSED",
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "prisma": "^6.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
