// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USERS & AUTHENTICATION
// ============================================================================

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique @db.VarChar(255)
  phone           String    @unique @db.VarChar(20)
  passwordHash    String    @map("password_hash") @db.VarChar(255)
  firstName       String    @map("first_name") @db.VarChar(100)
  lastName        String    @map("last_name") @db.VarChar(100)
  role            String    @db.VarChar(20) // 'consumer', 'farmer', 'admin'
  isVerified      Boolean   @default(false) @map("is_verified")
  isActive        Boolean   @default(true) @map("is_active")
  profileImageUrl String?   @map("profile_image_url") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  lastLoginAt     DateTime? @map("last_login_at") @db.Timestamp(6)

  // Relationships
  farmerProfile FarmerProfile?
  products      Product[]
  addresses     Address[]
  orders        Order[]
  reviews       Review[]        @relation("CustomerReviews")
  farmerReviews Review[]        @relation("FarmerReviews")
  notifications Notification[]
  orderItems    OrderItem[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@map("users")
}

// ============================================================================
// FARMER PROFILES
// ============================================================================

model FarmerProfile {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @unique @map("user_id") @db.Uuid
  farmName          String?   @map("farm_name") @db.VarChar(255)
  bio               String?   @db.Text
  locationCounty    String?   @map("location_county") @db.VarChar(100)
  locationSubcounty String?   @map("location_subcounty") @db.VarChar(100)
  locationDetails   String?   @map("location_details") @db.Text
  locationLat       Decimal?  @map("location_lat") @db.Decimal(10, 8)
  locationLng       Decimal?  @map("location_lng") @db.Decimal(11, 8)
  certifications    Json      @default("[]") @db.JsonB // ["organic", "fairtrade"]
  isVerified        Boolean   @default(false) @map("is_verified")
  verificationDate  DateTime? @map("verification_date") @db.Timestamp(6)
  ratingAvg         Decimal   @default(0.00) @map("rating_avg") @db.Decimal(3, 2)
  totalOrders       Int       @default(0) @map("total_orders")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([locationCounty, locationSubcounty])
  @@index([isVerified])
  @@map("farmer_profiles")
}

// ============================================================================
// CATEGORIES
// ============================================================================

model Category {
  id               String    @id @default(uuid()) @db.Uuid
  name             String    @unique @db.VarChar(100)
  slug             String    @unique @db.VarChar(100)
  description      String?   @db.Text
  iconUrl          String?   @map("icon_url") @db.Text
  parentCategoryId String?   @map("parent_category_id") @db.Uuid
  displayOrder     Int       @default(0) @map("display_order")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  // Relationships
  parentCategory Category?  @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id])
  subCategories  Category[] @relation("CategoryHierarchy")
  products       Product[]

  @@index([slug])
  @@index([parentCategoryId])
  @@map("categories")
}

// ============================================================================
// PRODUCTS
// ============================================================================

model Product {
  id           String   @id @default(uuid()) @db.Uuid
  farmerId     String   @map("farmer_id") @db.Uuid
  categoryId   String   @map("category_id") @db.Uuid
  name         String   @db.VarChar(255)
  description  String?  @db.Text
  unit         String   @db.VarChar(50) // "kg", "bunch", "piece"
  unitQuantity Decimal  @default(1.00) @map("unit_quantity") @db.Decimal(10, 2)
  priceKsh     Decimal  @map("price_ksh") @db.Decimal(10, 2)
  stockQuantity Int     @default(0) @map("stock_quantity")
  isOrganic    Boolean  @default(false) @map("is_organic")
  isAvailable  Boolean  @default(true) @map("is_available")
  images       Json     @default("[]") @db.JsonB // Array of image URLs
  tags         Json     @default("[]") @db.JsonB // ["fresh", "local", "seasonal"]
  ratingAvg    Decimal  @default(0.00) @map("rating_avg") @db.Decimal(3, 2)
  totalReviews Int      @default(0) @map("total_reviews")
  totalSold    Int      @default(0) @map("total_sold")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relationships
  farmer     User        @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  category   Category    @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  reviews    Review[]

  @@index([farmerId])
  @@index([categoryId])
  @@index([isAvailable])
  @@index([ratingAvg])
  @@map("products")
}

// ============================================================================
// ADDRESSES
// ============================================================================

model Address {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String   @map("user_id") @db.Uuid
  label                String?  @db.VarChar(50) // "Home", "Office"
  fullName             String   @map("full_name") @db.VarChar(255)
  phone                String   @db.VarChar(20)
  county               String   @db.VarChar(100)
  subcounty            String?  @db.VarChar(100)
  streetAddress        String   @map("street_address") @db.Text
  buildingDetails      String?  @map("building_details") @db.Text
  deliveryInstructions String?  @map("delivery_instructions") @db.Text
  locationLat          Decimal? @map("location_lat") @db.Decimal(10, 8)
  locationLng          Decimal? @map("location_lng") @db.Decimal(11, 8)
  isDefault            Boolean  @default(false) @map("is_default")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relationships
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@index([userId, isDefault])
  @@map("addresses")
}

// ============================================================================
// ORDERS
// ============================================================================

model Order {
  id                  String    @id @default(uuid()) @db.Uuid
  orderNumber         String    @unique @map("order_number") @db.VarChar(50) // "SKS-2024-001234"
  customerId          String    @map("customer_id") @db.Uuid
  deliveryAddressId   String    @map("delivery_address_id") @db.Uuid
  status              String    @default("pending") @db.VarChar(50)
  // pending, paid, confirmed, preparing, ready, in_transit, delivered, cancelled, refunded
  subtotalKsh         Decimal   @map("subtotal_ksh") @db.Decimal(10, 2)
  deliveryFeeKsh      Decimal   @default(0.00) @map("delivery_fee_ksh") @db.Decimal(10, 2)
  totalKsh            Decimal   @map("total_ksh") @db.Decimal(10, 2)
  paymentMethod       String    @default("mpesa") @map("payment_method") @db.VarChar(50)
  paymentStatus       String    @default("pending") @map("payment_status") @db.VarChar(50) // pending, completed, failed
  paymentRef          String?   @map("payment_ref") @db.VarChar(255) // M-Pesa transaction ID
  deliveryScheduledAt DateTime? @map("delivery_scheduled_at") @db.Timestamp(6)
  deliveredAt         DateTime? @map("delivered_at") @db.Timestamp(6)
  cancelledAt         DateTime? @map("cancelled_at") @db.Timestamp(6)
  cancellationReason  String?   @map("cancellation_reason") @db.Text
  notes               String?   @db.Text
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relationships
  customer        User          @relation(fields: [customerId], references: [id])
  deliveryAddress Address       @relation(fields: [deliveryAddressId], references: [id])
  orderItems      OrderItem[]
  transactions    Transaction[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([orderNumber])
  @@map("orders")
}

// ============================================================================
// ORDER ITEMS
// ============================================================================

model OrderItem {
  id              String   @id @default(uuid()) @db.Uuid
  orderId         String   @map("order_id") @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  farmerId        String   @map("farmer_id") @db.Uuid
  productName     String   @map("product_name") @db.VarChar(255) // Snapshot at order time
  unit            String   @db.VarChar(50)
  unitQuantity    Decimal  @map("unit_quantity") @db.Decimal(10, 2)
  pricePerUnitKsh Decimal  @map("price_per_unit_ksh") @db.Decimal(10, 2)
  quantity        Int
  subtotalKsh     Decimal  @map("subtotal_ksh") @db.Decimal(10, 2)
  status          String   @default("pending") @db.VarChar(50) // pending, confirmed, preparing, ready, delivered
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  // Relationships
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  farmer  User    @relation(fields: [farmerId], references: [id])
  review  Review?

  @@index([orderId])
  @@index([productId])
  @@index([farmerId])
  @@map("order_items")
}

// ============================================================================
// TRANSACTIONS
// ============================================================================

model Transaction {
  id                     String   @id @default(uuid()) @db.Uuid
  orderId                String   @map("order_id") @db.Uuid
  type                   String   @db.VarChar(50) // payment, refund, payout
  amountKsh              Decimal  @map("amount_ksh") @db.Decimal(10, 2)
  currency               String   @default("KES") @db.VarChar(10)
  paymentMethod          String?  @map("payment_method") @db.VarChar(50)
  paymentProvider        String?  @map("payment_provider") @db.VarChar(50) // mpesa, manual
  providerTransactionId  String?  @map("provider_transaction_id") @db.VarChar(255)
  providerReference      String?  @map("provider_reference") @db.VarChar(255)
  status                 String   @db.VarChar(50) // pending, completed, failed
  metadata               Json     @default("{}") @db.JsonB
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relationships
  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
  @@index([createdAt])
  @@map("transactions")
}

// ============================================================================
// REVIEWS
// ============================================================================

model Review {
  id                 String   @id @default(uuid()) @db.Uuid
  orderItemId        String   @unique @map("order_item_id") @db.Uuid
  customerId         String   @map("customer_id") @db.Uuid
  farmerId           String   @map("farmer_id") @db.Uuid
  productId          String   @map("product_id") @db.Uuid
  rating             Int // 1-5
  comment            String?  @db.Text
  images             Json     @default("[]") @db.JsonB
  isVerifiedPurchase Boolean  @default(true) @map("is_verified_purchase")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relationships
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
  customer  User      @relation("CustomerReviews", fields: [customerId], references: [id])
  farmer    User      @relation("FarmerReviews", fields: [farmerId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@index([farmerId])
  @@index([productId])
  @@index([customerId])
  @@map("reviews")
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  type      String    @db.VarChar(50) // order_update, payment_received, new_review, etc.
  title     String    @db.VarChar(255)
  message   String    @db.Text
  data      Json      @default("{}") @db.JsonB // Additional context
  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at") @db.Timestamp(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}
